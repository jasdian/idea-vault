# Copy to .env and adjust. docker compose reads .env automatically.

# Host uid/gid that owns ./vault. MUST match `id -u` / `id -g` or the container
# (which runs as this uid) cannot write the bind-mounted vault. Also passed as
# build args so the image's /data mountpoint is chowned to the same uid.
IDEA_VAULT_UID=1000
IDEA_VAULT_GID=1000

# Ollama model to use (and to pull via the ollama-pull one-shot). Must be a tag
# the Ollama registry knows, e.g. qwen3.5:4b, gpt-oss:20b, qwen3.6:27b — see "Choosing a model" in the README.
IDEA_VAULT_OLLAMA_MODEL=qwen3.5:4b

# --- Local .gguf import (optional) -------------------------------------------
# To run a local/fine-tuned weight file instead of a registry pull, import it as
# an Ollama model with the one-shot (reads the blob once into the ollama volume):
#   IDEA_VAULT_MODELS_DIR=/abs/path/to/gguf-dir IDEA_VAULT_GGUF=Your-Model-Q4_K_M.gguf \
#   IDEA_VAULT_OLLAMA_MODEL=my-local docker compose --profile tools run --rm ollama-import
# then set IDEA_VAULT_OLLAMA_MODEL=my-local here and `docker compose up -d`.
# GPU note: a 7–8B Q4_K_M (~5–6 GB) fits an 11 GB card only if no other model is
# resident; `docker exec idea-vault-ollama ollama ps` should show 100% GPU (not CPU).
IDEA_VAULT_MODELS_DIR=./llm-models
IDEA_VAULT_GGUF=model.gguf

# Host port to publish the UI on (loopback only). Change this if 3000 is already
# taken on your machine; open http://localhost:<this>. The container still listens
# on 3000 internally, so nothing else needs to change.
IDEA_VAULT_HOST_PORT=3000

# Host-side IP to publish the UI on. Defaults to loopback (127.0.0.1) — not
# reachable from your LAN. Set to 0.0.0.0 (all interfaces) or a specific LAN
# interface IP to expose the UI to other machines on your network.
# SECURITY: the app has no auth of its own — anyone who can reach this address
# can use it. Only opt in to LAN exposure on a trusted network. Ollama's own
# port stays loopback-only regardless of this setting.
IDEA_VAULT_HOST_BIND_IP=127.0.0.1

# --- Claude Code backend (optional, docs/adr/0009 + 0011 + 0013) -------------
# Second, agentic LLM backend: idea-vault shells out to your local, authenticated
# `claude` CLI instead of Ollama. Live-switchable on the Settings page, so these
# are only the INITIAL values.
#
# CONTAINERS: layer the claude override on top of the base compose file —
#   docker compose -f docker-compose.yml -f docker-compose.claude.yml up -d --build
# It bind-mounts the host CLI (ro) and defaults the backend to claude-code.
#
# To make that layering PERMANENT (recommended once you use claude-code at
# all), set COMPOSE_FILE here instead of typing the -f flags every time —
# otherwise a habitual `docker compose up -d` / `restart` silently rebuilds
# the stack WITHOUT the override and the foil goes offline. Colon-separated,
# base first; insert docker-compose.gpu.yml before the claude entry for GPU:
# COMPOSE_FILE=docker-compose.yml:docker-compose.claude.yml
#
# The two vars the override needs from here:
#
# Host path of the `claude` binary the override mounts into the container.
# The default matches the standard native install (a symlink Docker dereferences
# at container start — `restart idea-vault` picks up a host CLI update).
# IDEA_VAULT_CLAUDE_HOST_BIN=~/.local/bin/claude
#
# Long-lived auth token for the in-container CLI. One-time on the host:
#   claude setup-token
# and paste the result here. REQUIRED by the claude override — `up` fails fast
# with a clear message when it is unset.
# CLAUDE_CODE_OAUTH_TOKEN=
#
# The claude override already defaults the backend to claude-code; set this only
# to override that (boot the container with Ollama anyway) or to enable
# claude-code on a NATIVE run. Leave unset for Ollama otherwise.
# IDEA_VAULT_LLM_BACKEND=claude-code
#
# Model alias passed to `claude --model` (blank = the CLI default). e.g. opus, sonnet, haiku.
# IDEA_VAULT_CLAUDE_MODEL=opus
#
# Reasoning-effort hint (low|medium|high) injected into the system prompt.
# IDEA_VAULT_CLAUDE_EFFORT=high
#
# The `claude` binary — NATIVE runs only. Defaults to bare `claude` (resolved on
# PATH), but a native server process often has a narrower PATH than your shell,
# so point this at an ABSOLUTE path if /admin/health reports the claude backend
# "unreachable" (the probe logs exactly why in the server log). Do NOT set for
# containers: the claude override fixes it to /opt/claude/claude.
# IDEA_VAULT_CLAUDE_BIN=/home/you/.local/bin/claude

# --- Dynamic context budget (optional, docs/adr/0014) -------------------------
# The AI prompt budget is derived live per backend/model (Ollama: the model's
# native window from `POST /api/show`, capped at 32768 tokens, falling back to
# 8192 until the cache warms; claude-code: 1,000,000 tokens if the model name
# contains "1m", else 200,000 — no default cap). These are per-backend manual
# overrides in TOKENS; 0 (default) = auto. Nonzero values are clamped to
# 1024..=2000000. Only the INITIAL values — retunable live on the Settings page.
# Containers: the base compose forwards the Ollama override; the claude override
# file forwards the claude one.
#
# IDEA_VAULT_OLLAMA_CTX_TOKENS=0
# IDEA_VAULT_CLAUDE_CTX_TOKENS=0

# App log level (tracing EnvFilter syntax).
RUST_LOG=info

# ── Web access (ADR-0017) ────────────────────────────────────────────────────
# Let the foil crawl the internet: web_search + fetch_url tools on Ollama
# (bounded tool-calling loop), WebSearch/WebFetch on claude-code. Default: true.
# Set false for a fully offline run; live-toggleable on the Settings page.
# The search endpoint is keyless DuckDuckGo HTML; point IDEA_VAULT_SEARCH_URL
# at a SearXNG-style HTML endpoint to self-host it.
#
# IDEA_VAULT_WEB_ACCESS=true
# IDEA_VAULT_SEARCH_URL=https://html.duckduckgo.com/html/

# ── MCP servers ──────────────────────────────────────────────────────────────
# Where the MCP server registry JSON lives (the owner-configured list of Model
# Context Protocol endpoints whose tools the foil may call, on both backends).
# Defaults to <vault dir>/.mcp-servers.json — inside the vault bind mount so it
# persists across container rebuilds, but as a dotfile the idea index never
# reads (it is app config, not vault truth). Override only to move it elsewhere.
#
# IDEA_VAULT_MCP_CONFIG=/data/vault/.mcp-servers.json
