# Copy to .env and adjust. docker compose reads .env automatically.

# Host uid/gid that owns ./vault. MUST match `id -u` / `id -g` or the container
# (which runs as this uid) cannot write the bind-mounted vault. Also passed as
# build args so the image's /data mountpoint is chowned to the same uid.
IDEA_VAULT_UID=1000
IDEA_VAULT_GID=1000

# Ollama model to use (and to pull via the ollama-pull one-shot). Must be a tag
# the Ollama registry knows, e.g. qwen3.5:4b, gpt-oss:20b, qwen3.6:27b — see "Choosing a model" in the README.
IDEA_VAULT_OLLAMA_MODEL=qwen3.5:4b

# App log level (tracing EnvFilter syntax).
RUST_LOG=info
