# Copy to .env and adjust. docker compose reads .env automatically.

# Host uid/gid that owns ./vault. MUST match `id -u` / `id -g` or the container
# (which runs as this uid) cannot write the bind-mounted vault. Also passed as
# build args so the image's /data mountpoint is chowned to the same uid.
IDEA_VAULT_UID=1000
IDEA_VAULT_GID=1000

# Ollama model to use (and to pull via the ollama-pull one-shot). Must be a tag
# the Ollama registry knows, e.g. qwen3.5:4b, gpt-oss:20b, qwen3.6:27b — see "Choosing a model" in the README.
IDEA_VAULT_OLLAMA_MODEL=qwen3.5:4b

# --- Local .gguf import (optional) -------------------------------------------
# To run a local/fine-tuned weight file instead of a registry pull, import it as
# an Ollama model with the one-shot (reads the blob once into the ollama volume):
#   IDEA_VAULT_MODELS_DIR=/abs/path/to/gguf-dir IDEA_VAULT_GGUF=Your-Model-Q4_K_M.gguf \
#   IDEA_VAULT_OLLAMA_MODEL=my-local docker compose --profile tools run --rm ollama-import
# then set IDEA_VAULT_OLLAMA_MODEL=my-local here and `docker compose up -d`.
# GPU note: a 7–8B Q4_K_M (~5–6 GB) fits an 11 GB card only if no other model is
# resident; `docker exec idea-vault-ollama ollama ps` should show 100% GPU (not CPU).
IDEA_VAULT_MODELS_DIR=./llm-models
IDEA_VAULT_GGUF=model.gguf

# Host port to publish the UI on (loopback only). Change this if 3000 is already
# taken on your machine; open http://localhost:<this>. The container still listens
# on 3000 internally, so nothing else needs to change.
IDEA_VAULT_HOST_PORT=3000

# --- Claude Code backend (optional, docs/adr/0009 + 0011) --------------------
# Second, agentic LLM backend: idea-vault shells out to your local, authenticated
# `claude` CLI instead of Ollama. Live-switchable on the Settings page, so these
# are only the INITIAL values. Leave IDEA_VAULT_LLM_BACKEND unset for Ollama.
#
# IDEA_VAULT_LLM_BACKEND=claude-code
#
# The `claude` binary. Defaults to bare `claude` (resolved on PATH) — fine inside
# the container, but a NATIVE run's server process often has a narrower PATH than
# your shell, so point this at an ABSOLUTE path if /admin/health reports the
# claude backend "unreachable" (the probe now logs exactly why in the server log).
# IDEA_VAULT_CLAUDE_BIN=/home/you/.local/bin/claude
#
# Model alias passed to `claude --model` (blank = the CLI default). e.g. opus, sonnet, haiku.
# IDEA_VAULT_CLAUDE_MODEL=opus
#
# Reasoning-effort hint (low|medium|high) injected into the system prompt.
# IDEA_VAULT_CLAUDE_EFFORT=high

# App log level (tracing EnvFilter syntax).
RUST_LOG=info
